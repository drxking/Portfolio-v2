{
    "builds": [
        {
            "src": "src/**/*",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/dist/$1"
        }
    ],
    "redirects": [
        {
            "source": "/dist/(.*)",
            "destination": "/",
            "permanent": true
        }
    ]
}