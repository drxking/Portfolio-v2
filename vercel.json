{
    "builds": [
        {
            "src": "src/**/*",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "routes": [
        {
            "src": "/",
            "dest": "/dist/index.html"
        },
        {
            "src": "/(.*)",
            "dest": "/dist/$1"
        }
    ]
}